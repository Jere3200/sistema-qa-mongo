# MongoDB Atlas — cadena de conexión de Prisma
DATABASE_URL=

# NextAuth (Auth.js v5)
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Resend — envío de emails (reset de contraseña)
RESEND_API_KEY=
# Remitente verificado en tu dominio de Resend (ej. no-reply@tudominio.com)
EMAIL_FROM=

# URL pública de la app — usada para construir el link de reset de contraseña
# (de confianza, no se deriva del header Host). Ej: https://tudominio.com
NEXT_PUBLIC_APP_URL=

# Cloudflare Turnstile (CAPTCHA en login y registro)
# Si quedan vacías, el CAPTCHA se desactiva automáticamente.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
